---
// Sidebar.astro
---

<nav class="section-nav" aria-label="Case study section navigation">
  <div class="section-nav__bar">
    <button class="section-nav__btn section-nav__btn--nav" type="button" data-dir="prev" aria-label="Go to previous section">
      <span aria-hidden="true">&larr;</span>
    </button>

    <button
      class="section-nav__summary"
      type="button"
      aria-label="Toggle section list"
      aria-expanded="false"
      aria-controls="section-nav-sections-list"
    >
      <span class="section-nav__current-wrap">
        <span class="section-nav__eyebrow">On this page</span>
        <span class="section-nav__current" aria-live="polite">Current section</span>
      </span>
      <span class="section-nav__summary-icon" aria-hidden="true">▾</span>
    </button>

    <button class="section-nav__btn section-nav__btn--nav" type="button" data-dir="next" aria-label="Go to next section">
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>

  <div class="section-nav__panel" id="section-nav-sections-list" aria-hidden="true">
    <ul class="section-nav__list"></ul>
  </div>
</nav>

<script>
  // @ts-nocheck
  function initSidebar() {
    const sectionNav = document.querySelector('.section-nav');
    if (!(sectionNav instanceof HTMLElement) || sectionNav.dataset.initialized === 'true') return;

    const sectionNavList = sectionNav.querySelector('.section-nav__list');
    const sectionPanel = sectionNav.querySelector('.section-nav__panel');
    const summaryToggle = sectionNav.querySelector('.section-nav__summary');
    const previousButton = sectionNav.querySelector('[data-dir="prev"]');
    const followingButton = sectionNav.querySelector('[data-dir="next"]');
    const currentSectionLabel = sectionNav.querySelector('.section-nav__current');

    if (!(sectionNavList instanceof HTMLUListElement)) return;

    const heroOverview = document.querySelector('.hero-content-casestudy[data-section-label]');
    const headings = Array.from(document.querySelectorAll('.content-case-study h2')).filter(
      (heading) => heading instanceof HTMLHeadingElement
    );

    if (!heroOverview && headings.length === 0) return;

    sectionNav.dataset.initialized = 'true';
    sectionNavList.innerHTML = '';

    const usedIds = new Set();
    const headingsData = [];

    if (heroOverview instanceof HTMLElement) {
      const heroLabel = heroOverview.dataset.sectionLabel?.trim() || 'Intro';
      if (!heroOverview.id) {
        heroOverview.id = 'case-study-top';
      }
      usedIds.add(heroOverview.id);
      headingsData.push({
        heading: heroOverview,
        label: truncateLabel(heroLabel, 40),
        fullLabel: heroLabel,
        id: heroOverview.id
      });
    }

    headings.forEach((heading, index) => {
      const rawText = heading.textContent?.trim() ?? '';
      const label = truncateLabel(rawText, 40);
      const id = ensureHeadingId(heading, rawText, index, usedIds);
      headingsData.push({
        heading,
        label,
        fullLabel: rawText || `Section ${index + 1}`,
        id
      });
    });

    // Generate navigation links.
    headingsData.forEach((item) => {
      const li = document.createElement('li');
      li.className = 'section-nav__item';

      const a = document.createElement('a');
      a.className = 'section-nav__link';
      a.href = `#${item.id}`;
      a.textContent = item.label;
      a.title = item.fullLabel;
      a.setAttribute('data-target-id', item.id);

      a.addEventListener('click', (event) => {
        event.preventDefault();
        scrollToHeading(item.heading);
        setExpanded(false);
      });

      li.appendChild(a);
      sectionNavList.appendChild(li);
    });

    // Show section nav.
    sectionNav.classList.add('section-nav--visible');

    document.body.classList.add('has-section-sidebar');

    let activeIndex = 0;
    let isExpanded = false;
    const links = Array.from(sectionNavList.querySelectorAll('.section-nav__link'));

    function getScrollOffset() {
      const desktop = window.matchMedia('(min-width: 768px)').matches;
      const cssVar = desktop ? '--nav-height-desktop' : '--nav-height-mob';
      const navHeight = Number.parseFloat(getComputedStyle(document.documentElement).getPropertyValue(cssVar)) || 80;
      return navHeight + 16;
    }

    function scrollToHeading(heading) {
      const targetTop = heading.getBoundingClientRect().top + window.scrollY - getScrollOffset();
      window.scrollTo({
        top: Math.max(0, targetTop),
        behavior: 'smooth'
      });
    }

    function setExpanded(nextState) {
      isExpanded = nextState;
      sectionNav.classList.toggle('section-nav--expanded', isExpanded);
      if (sectionPanel) {
        sectionPanel.setAttribute('aria-hidden', String(!isExpanded));
      }
      if (summaryToggle) {
        summaryToggle.setAttribute('aria-expanded', String(isExpanded));
        summaryToggle.classList.toggle('section-nav__summary--expanded', isExpanded);
      }
    }

    function setCurrentLabel(text) {
      if (!currentSectionLabel || currentSectionLabel.textContent === text) return;
      currentSectionLabel.classList.add('section-nav__current--changing');
      window.setTimeout(() => {
        currentSectionLabel.textContent = text;
        currentSectionLabel.classList.remove('section-nav__current--changing');
      }, 90);
    }

    function updateDirectionalButtons() {
      if (previousButton) {
        previousButton.disabled = activeIndex <= 0;
      }
      if (followingButton) {
        followingButton.disabled = activeIndex >= headingsData.length - 1;
      }
    }

    function updateActiveLink() {
      const scrollPos = window.scrollY + getScrollOffset() + 8;
      let currentIndex = 0;

      for (let i = 0; i < headingsData.length; i += 1) {
        if (headingsData[i].heading.offsetTop <= scrollPos) {
          currentIndex = i;
        }
      }

      activeIndex = currentIndex;
      links.forEach((link, index) => {
        link.classList.toggle('section-nav__link--active', index === activeIndex);
      });

      setCurrentLabel(headingsData[activeIndex].label);
      updateDirectionalButtons();
    }

    if (summaryToggle) {
      summaryToggle.addEventListener('click', () => {
        setExpanded(!isExpanded);
      });
    }

    if (previousButton) {
      previousButton.addEventListener('click', () => {
        if (activeIndex <= 0) return;
        const nextIndex = activeIndex - 1;
        scrollToHeading(headingsData[nextIndex].heading);
      });
    }

    if (followingButton) {
      followingButton.addEventListener('click', () => {
        if (activeIndex >= headingsData.length - 1) return;
        const nextIndex = activeIndex + 1;
        scrollToHeading(headingsData[nextIndex].heading);
      });
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        updateActiveLink();
        ticking = false;
      });
    }, { passive: true });

    window.addEventListener('resize', () => {
      updateActiveLink();
    });

    updateActiveLink();

    /**
     * @param {HTMLHeadingElement} heading
     * @param {string} text
     * @param {number} index
     * @param {Set<string>} idSet
     */
    function ensureHeadingId(heading, text, index, idSet) {
      const existingId = heading.id?.trim();
      if (existingId) {
        idSet.add(existingId);
        return existingId;
      }

      const base = slugify(text) || `section-${index + 1}`;
      let candidate = base;
      let increment = 2;

      while (idSet.has(candidate) || document.getElementById(candidate)) {
        candidate = `${base}-${increment}`;
        increment += 1;
      }

      heading.id = candidate;
      idSet.add(candidate);
      return candidate;
    }

    function slugify(value) {
      return value
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
    }

    function truncateLabel(value, maxLength) {
      if (!value) return 'Section';
      if (value.length <= maxLength) return value;
      return `${value.slice(0, maxLength - 1).trimEnd()}…`;
    }
  }
  
  // Initialize when page loads
  document.addEventListener('DOMContentLoaded', initSidebar);
  
  // Handle Astro page transitions
  document.addEventListener('astro:page-load', initSidebar);
</script>