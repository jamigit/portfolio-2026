---
import { Image } from 'astro:assets';

export interface Props {
  title: string;
  description: string;
  url: string;
  image: { url: string; alt: string; };
  optimizedImage?: any;
  order: number;
  bgClass?: string;
}

const { title, description, url, image, optimizedImage, order, bgClass } = Astro.props;
const orderLabel = String(order).padStart(2, '0') + '.';
---

<li class="workitem-container">
  <a class="workitem" href={url} data-bg={bgClass}>
    <div class="workitem-inner">
      <div class="workitem-left">
        <span class="case-number">{orderLabel}</span>
        <h3 class="workitem-title">{title}</h3>
        <p class="overview-text-small">{description}</p>
        <span class="workitem-cta"><span class="workitem-cta-label">Read case study</span><span class="workitem-cta-arrow" aria-hidden="true">→</span></span>
      </div>

      <div class="workitem-right">
        <div class="workitem-image-wrap">
          {optimizedImage && (
            <Image
              src={optimizedImage}
              alt={image.alt}
              width={700}
              format="webp"
              loading="lazy"
              class="workitem-img"
              quality={80}
            />
          )}
        </div>
      </div>
    </div>
  </a>
</li>
