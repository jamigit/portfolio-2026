---
import { Image } from 'astro:assets';
import TagBadge from './TagBadge.astro';

export interface Props {
  title: string;
  description: string;
  url: string;
  image: { url: string; alt: string; };
  optimizedImage?: any;
  order: number;
  accentColor?: string;
}

const { title, description, url, image, optimizedImage, order, accentColor = '#F7C099' } = Astro.props;
const orderLabel = String(order).padStart(2, '0') + '.';
---

<li class="workitem-container">
  <a class="workitem" href={url} style={`--workitem-accent: ${accentColor}`}>
    <div class="workitem-inner">
      <div class="workitem-text">
        <span class="case-number">{orderLabel}</span>
        <TagBadge label="Case Study" />
        <h3 class="workitem-title">{title}</h3>
        <p class="overview-text-small">{description}</p>
        <span class="workitem-cta">Read</span>
      </div>
      <div class="workitem-image-wrap">
        <div class="workitem-accent-circle" aria-hidden="true"></div>
        {optimizedImage ? (
          <Image
            src={optimizedImage}
            alt={image.alt}
            width={700}
            format="webp"
            loading="lazy"
            class="workitem-img"
            quality={80}
          />
        ) : (
          <img src={image.url} alt={image.alt} class="workitem-img" />
        )}
      </div>
    </div>
  </a>
</li>
