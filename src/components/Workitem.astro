---
import { Image } from 'astro:assets';
import TagBadge from './TagBadge.astro';

export interface Props {
  title: string;
  description: string;
  url: string;
  image: { url: string; alt: string; };
  optimizedImage?: any;
  order: number;
  bgClass?: string;
}

const { title, description, url, image, optimizedImage, order, bgClass } = Astro.props;
const orderLabel = String(order).padStart(2, '0') + '.';
---

<li class="workitem-container">
  <a class="workitem" href={url} data-bg={bgClass}>
    <div class="workitem-inner">
      <div class="workitem-text workitem-text--head">
        <span class="case-number">{orderLabel}</span>
        <TagBadge label="Case Study" />
        <h3 class="workitem-title">{title}</h3>
      </div>

      <div class="workitem-image-wrap">
        {optimizedImage && (
          <Image
            src={optimizedImage}
            alt={image.alt}
            width={700}
            format="webp"
            loading="lazy"
            class="workitem-img"
            quality={80}
          />
        )}
      </div>

      <div class="workitem-text workitem-text--body">
        <p class="overview-text-small">{description}</p>
        <span class="workitem-cta"><span class="workitem-cta-label">Read</span><span class="workitem-cta-arrow" aria-hidden="true">→</span></span>
      </div>
    </div>
  </a>
</li>
