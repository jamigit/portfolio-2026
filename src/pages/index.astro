---
import IndexLayout from '../layouts/IndexLayout.astro';
import Workitem from '../components/Workitem.astro';
import WorkitemProject from '../components/WorkitemProject.astro';

// Import all hero images
import auroraHomeShadow from '../assets/images/hero/Aurora-home-shadow.png';
import folHomeShadow from '../assets/images/hero/FoL-Home-shadow.png';
import gbagHomeShadow from '../assets/images/hero/Gbag-home-shadow.png';
import healthywaterwaysHero from '../assets/images/hero/healthywaterways-hero.png';
import jfnHomeShadow from '../assets/images/hero/JFN-home-shadow.png';
import keplaHero from '../assets/images/hero/kepla-hero.png';
import npdcHero from '../assets/images/hero/npdc-hero.png';
import pelorusHero from '../assets/images/hero/pelorus-hero.png';
import quinovicShadow from '../assets/images/hero/quinovic-shadow.png';
import rmssHero from '../assets/images/hero/rmss-hero.png';
import sitesafeHero from '../assets/images/hero/sitesafe-hero.png';
import times7HomeShadow from '../assets/images/hero/times7-home-shadow.png';
import vocalHomeShadow from '../assets/images/hero/vocal-home-shadow.png';

const heroImages = {
  'Aurora-home-shadow.png': auroraHomeShadow,
  'FoL-Home-shadow.png': folHomeShadow,
  'Gbag-home-shadow.png': gbagHomeShadow,
  'healthywaterways-hero.png': healthywaterwaysHero,
  'JFN-home-shadow.png': jfnHomeShadow,
  'kepla-hero.png': keplaHero,
  'npdc-hero.png': npdcHero,
  'pelorus-hero.png': pelorusHero,
  'quinovic-shadow.png': quinovicShadow,
  'rmss-hero.png': rmssHero,
  'sitesafe-hero.png': sitesafeHero,
  'times7-home-shadow.png': times7HomeShadow,
  'vocal-home-shadow.png': vocalHomeShadow,
};

const allPosts = Object.values(import.meta.glob('../pages/case-study/*.mdx', { eager: true }));
const allProjects = Object.values(import.meta.glob('../pages/projects/*.mdx', { eager: true }));

const getOptimizedImage = (imagePath) => {
  if (!imagePath || !imagePath.url) return null;
  const filename = imagePath.url.split('/').pop();
  return heroImages[filename] || null;
};

const processedCaseStudies = allPosts
  .map((post: any) => ({ ...post, optimizedImage: getOptimizedImage(post.frontmatter.image) }))
  .sort((a, b) => (a.frontmatter.order || 999) - (b.frontmatter.order || 999));

const processedProjects = allProjects
  .map((post: any) => ({ ...post, optimizedImage: getOptimizedImage(post.frontmatter.image) }))
  .sort((a, b) => (a.frontmatter.order || 999) - (b.frontmatter.order || 999));
---
<IndexLayout>
  <Fragment slot="hero">
    <h1 class="hero-display-title">Jamie Barter</h1>
    <p class="hero-subtext">UX and Product Design Lead</p>
  </Fragment>

  <h2 class="small-title" id="case-studies">Case studies</h2>
  <ul class="list-workitems">
    {processedCaseStudies.map((post: any) => (
      <Workitem
        url={post.url}
        title={post.frontmatter.title}
        description={post.frontmatter.description}
        image={post.frontmatter.image}
        optimizedImage={post.optimizedImage}
        order={post.frontmatter.order}
        accentColor={post.frontmatter.accentColor}
      />
    ))}
  </ul>

  <h2 class="small-title" id="projects">Projects</h2>
  <ul class="list-workitems">
    {processedProjects.map((post: any) => (
      <WorkitemProject
        url={post.url}
        title={post.frontmatter.title}
        description={post.frontmatter.description}
        image={post.frontmatter.image}
        optimizedImage={post.optimizedImage}
        order={post.frontmatter.order}
      />
    ))}
  </ul>
</IndexLayout>
