---
const { frontmatter } = Astro.props;

import BaseLayout from "./BaseLayout.astro";
import { Image } from 'astro:assets';
import Button from '../components/Button.astro';
import TagBadge from '../components/TagBadge.astro';
import Sidebar from '../components/Sidebar.astro';

// Import all hero images
import auroraHomeShadow from '../assets/images/hero/Aurora-home-shadow.png';
import folHomeShadow from '../assets/images/hero/FoL-Home-shadow.png';
import gbagHomeShadow from '../assets/images/hero/Gbag-home-shadow.png';
import healthywaterwaysHero from '../assets/images/hero/healthywaterways-hero.png';
import jfnHomeShadow from '../assets/images/hero/JFN-home-shadow.png';
import keplaHero from '../assets/images/hero/kepla-hero.png';
import npdcHero from '../assets/images/hero/npdc-hero.png';
import pelorusHero from '../assets/images/hero/pelorus-hero.png';
import quinovicShadow from '../assets/images/hero/quinovic-shadow.png';
import rmssHero from '../assets/images/hero/rmss-hero.png';
import sitesafeHero from '../assets/images/hero/sitesafe-hero.png';
import times7HomeShadow from '../assets/images/hero/times7-home-shadow.png';
import vocalHomeShadow from '../assets/images/hero/vocal-home-shadow.png';

const { image, customData, title, metaTitle, metaDescription, author } = frontmatter;

const heroImages = {
  'Aurora-home-shadow.png': auroraHomeShadow,
  'FoL-Home-shadow.png': folHomeShadow,
  'Gbag-home-shadow.png': gbagHomeShadow,
  'healthywaterways-hero.png': healthywaterwaysHero,
  'JFN-home-shadow.png': jfnHomeShadow,
  'kepla-hero.png': keplaHero,
  'npdc-hero.png': npdcHero,
  'pelorus-hero.png': pelorusHero,
  'quinovic-shadow.png': quinovicShadow,
  'rmss-hero.png': rmssHero,
  'sitesafe-hero.png': sitesafeHero,
  'times7-home-shadow.png': times7HomeShadow,
  'vocal-home-shadow.png': vocalHomeShadow,
};

const imageFilename = image.url.split('/').pop();
const heroImageSrc = imageFilename
  ? heroImages[imageFilename as keyof typeof heroImages]
  : undefined;
const topNavLabel = frontmatter.navOverviewLabel ?? 'Intro';
const heroClasses = `hero hero-casestudy has-canvas-hero hero-grid-visible grid ${frontmatter.bgClass ?? ''}`.trim();
---

<BaseLayout
  customData={customData}
  bodyClass="article-grid-visible"
  title={title}
  metaTitle={metaTitle ?? title}
  metaDescription={metaDescription ?? frontmatter.description}
  author={author}
  image={image}
  ogType="article"
>
  <!-- JSON-LD CreativeWork Schema -->
  <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": frontmatter.title,
    "creator": { "@type": "Person", "name": "Jamie Barter" },
    "description": frontmatter.overview,
    "client": frontmatter.client,
    "dateCreated": frontmatter.timeframe
  })} />
  <section class={heroClasses} id="case-study-top">
    <div id="casestudy-hero-bg" class="hero-bg-layer"></div>
    <div class="hero-content hero-content-casestudy col-content" data-section-label={topNavLabel}>
      <TagBadge label="Case Study" />
      <h1 class="banner-text">{frontmatter.title}</h1>
      <p class="overview-text-small">{frontmatter.overview}</p>

      {heroImageSrc ? (
        <Image
          src={heroImageSrc}
          alt={frontmatter.image.alt}
          width={1200}
          height={800}
          format="webp"
          loading="eager"
          class="hero-image"
          quality={85}
          densities={[1, 2]}
        />
      ) : null}

      <dl class="info">
        {frontmatter.client && (
          <div class="info-item">
            <dt>Client</dt>
            <dd>{frontmatter.client}</dd>
          </div>
        )}
        {frontmatter.projectType && (
          <div class="info-item">
            <dt>Project Type</dt>
            <dd>{frontmatter.projectType}</dd>
          </div>
        )}
        {frontmatter.role && (
          <div class="info-item">
            <dt>Role</dt>
            <dd>{frontmatter.role}</dd>
          </div>
        )}
        {frontmatter.timeframe && (
          <div class="info-item">
            <dt>Timeframe</dt>
            <dd>{frontmatter.timeframe}</dd>
          </div>
        )}
        {frontmatter.team && (
          <div class="info-item">
            <dt>Team</dt>
            <dd>{frontmatter.team}</dd>
          </div>
        )}
        {frontmatter.skills && (
          <div class="info-item">
            <dt>Skills</dt>
            <dd>{frontmatter.skills}</dd>
          </div>
        )}
      </dl>

      {frontmatter.projectLink && (
        <Button href={frontmatter.projectLink} variant="outline" external>
          {frontmatter.projectLinkCopy ?? 'See more'}
        </Button>
      )}
    </div>
  </section>

  <section class="content content-case-study grid">
    <div class="col-content">
      <slot />
    </div>
  </section>

  <Sidebar />
</BaseLayout>

<script is:inline>
  (function() {
    const heroBg = document.getElementById('casestudy-hero-bg');
    if (!heroBg) return;

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const maxScroll = window.innerHeight * 0.8;
      
      let opacity = 1 - (scrollY / maxScroll);
      opacity = Math.max(0, Math.min(1, opacity));
      
      heroBg.style.opacity = opacity.toFixed(3);
    }, { passive: true });
  })();
</script>
