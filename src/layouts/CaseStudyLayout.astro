---
const { frontmatter } = Astro.props;

import BaseLayout from "./BaseLayout.astro";
import { Image } from 'astro:assets';
import Button from '../components/Button.astro';
import TagBadge from '../components/TagBadge.astro';

// Import all hero images
import auroraHomeShadow from '../assets/images/hero/Aurora-home-shadow.png';
import folHomeShadow from '../assets/images/hero/FoL-Home-shadow.png';
import gbagHomeShadow from '../assets/images/hero/Gbag-home-shadow.png';
import healthywaterwaysHero from '../assets/images/hero/healthywaterways-hero.png';
import jfnHomeShadow from '../assets/images/hero/JFN-home-shadow.png';
import keplaHero from '../assets/images/hero/kepla-hero.png';
import npdcHero from '../assets/images/hero/npdc-hero.png';
import pelorusHero from '../assets/images/hero/pelorus-hero.png';
import quinovicShadow from '../assets/images/hero/quinovic-shadow.png';
import rmssHero from '../assets/images/hero/rmss-hero.png';
import sitesafeHero from '../assets/images/hero/sitesafe-hero.png';
import times7HomeShadow from '../assets/images/hero/times7-home-shadow.png';
import vocalHomeShadow from '../assets/images/hero/vocal-home-shadow.png';

const { image, customData, title, metaTitle, metaDescription, author } = frontmatter;

const heroImages = {
  'Aurora-home-shadow.png': auroraHomeShadow,
  'FoL-Home-shadow.png': folHomeShadow,
  'Gbag-home-shadow.png': gbagHomeShadow,
  'healthywaterways-hero.png': healthywaterwaysHero,
  'JFN-home-shadow.png': jfnHomeShadow,
  'kepla-hero.png': keplaHero,
  'npdc-hero.png': npdcHero,
  'pelorus-hero.png': pelorusHero,
  'quinovic-shadow.png': quinovicShadow,
  'rmss-hero.png': rmssHero,
  'sitesafe-hero.png': sitesafeHero,
  'times7-home-shadow.png': times7HomeShadow,
  'vocal-home-shadow.png': vocalHomeShadow,
};

const imageFilename = image.url.split('/').pop();
const heroImageSrc = heroImages[imageFilename];
const heroClasses = `hero hero-casestudy grid ${frontmatter.bgClass ?? ''}`.trim();
---

<BaseLayout
  customData={customData}
  title={title}
  metaTitle={metaTitle ?? title}
  metaDescription={metaDescription ?? frontmatter.description}
  author={author}
  image={image}
>
  <section class={heroClasses}>
    <div class="hero-content hero-content-casestudy col-content">
      <TagBadge label="Case Study" />
      <h1 class="banner-text">{frontmatter.title}</h1>
      <p class="overview-text-small">{frontmatter.overview}</p>

      {heroImageSrc ? (
        <Image
          src={heroImageSrc}
          alt={frontmatter.image.alt}
          width={1200}
          height={800}
          format="webp"
          loading="eager"
          class="hero-image"
          quality={85}
          densities={[1, 2]}
        />
      ) : null}

      <div class="info">
        {frontmatter.client && (
          <div class="info-item">
            <h5>Client</h5>
            <p>{frontmatter.client}</p>
          </div>
        )}
        {frontmatter.projectType && (
          <div class="info-item">
            <h5>Project Type</h5>
            <p>{frontmatter.projectType}</p>
          </div>
        )}
        {frontmatter.role && (
          <div class="info-item">
            <h5>Role</h5>
            <p>{frontmatter.role}</p>
          </div>
        )}
        {frontmatter.timeframe && (
          <div class="info-item">
            <h5>Timeframe</h5>
            <p>{frontmatter.timeframe}</p>
          </div>
        )}
        {frontmatter.team && (
          <div class="info-item">
            <h5>Team</h5>
            <p>{frontmatter.team}</p>
          </div>
        )}
        {frontmatter.skills && (
          <div class="info-item">
            <h5>Skills</h5>
            <p>{frontmatter.skills}</p>
          </div>
        )}
      </div>

      {frontmatter.projectLink && (
        <Button href={frontmatter.projectLink} variant="outline" external>
          {frontmatter.projectLinkCopy ?? 'See more'}
        </Button>
      )}
    </div>
  </section>

  <section class="content content-case-study grid">
    <slot />
  </section>
</BaseLayout>
