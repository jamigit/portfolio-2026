---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GridOverlay from '../components/GridOverlay.astro';
import '../styles/global.css';

const { title, metaTitle, metaDescription, author, customData, bodyClass = '', ogType = 'website' } = Astro.props;

const resolvedTitle = metaTitle ?? title ?? 'Jamie Barter — UX & Product Design';
const resolvedDescription = metaDescription ?? 'UX and Product Design Lead with 5+ years experience designing B2B SaaS products and web applications.';
const siteUrl = 'https://jamiebarter.com';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="author" content={author ?? "Jamie Barter"} />

    <!-- Canonical -->
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/PPPaloma-Heavy.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/PPNeueMontreal-Book.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Jamie Barter" />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:alt" content="Jamie Barter — UX & Product Design" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- JSON-LD Person Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jamie Barter",
      "url": "https://jamiebarter.com",
      "jobTitle": "Lead Product Designer",
      "worksFor": { "@type": "Organization", "name": "Do AI" },
      "description": "UX and Product Design Lead with 5+ years experience designing B2B SaaS products and web applications.",
      "sameAs": ["https://www.linkedin.com/in/jamie-barter/"]
    }
    </script>

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/favicon-32.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class={`site-body ${bodyClass}`.trim()}>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <GridOverlay />
    <div class="grid page-grid-anchor" aria-hidden="true"></div>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/menu.js"></script>
    <script src="../scripts/sync-grid-overlay.js"></script>
  </body>
</html>
